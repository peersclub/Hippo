# Hippo local dev configuration.
# Copy to .env (gitignored) and fill in — the root `pnpm dev` script sources
# it before turbo runs; every var here is declared in turbo.json's
# globalPassThroughEnv. All services read env ONCE at boot: changing a value
# needs a full `pnpm dev` restart.
#
# Everything below is OPTIONAL. With an empty .env the stack still runs —
# LLM falls back to the deterministic mock, stores fall back to in-memory
# (blank on every restart), and token-gated admin surfaces stay disabled.

# ── LLM provider (services/intelligence) ────────────────────────────────────
# Any OpenAI-compatible /v1/chat/completions endpoint: OpenRouter, vLLM, or
# local Ollama (http://localhost:11434/v1, no key). Without a reachable
# endpoint the provider router serves mock briefs and /health says mode=mock.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=anthropic/claude-haiku-4.5
LLM_API_KEY=sk-or-v1-your-key-here

# ── Durable stores (admin, memory, gateway MAU, portal) ─────────────────────
# Postgres with the migrations applied:
#   createdb hippo && pnpm --filter @hippo/stores migrate
# Unset = in-memory stores (fine for a quick look, wiped on restart).
DATABASE_URL=postgres://hippo:hippo@localhost:5432/hippo

# Redis-backed answer cache (services/intelligence). Unset = in-process cache.
# REDIS_URL=redis://localhost:6379

# ── Service-to-service auth ─────────────────────────────────────────────────
# Shared secret guarding gateway /internal/sessions and memory /admin/*.
# Fail-closed: these surfaces return 503 until it is set. Generate one:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
INTERNAL_API_TOKEN=

# ── Admin panel (services/admin :8794, UI :5175) ────────────────────────────
# First-boot operator, created only while the operator table is empty.
ADMIN_BOOTSTRAP_EMAIL=admin@hippo.local
ADMIN_BOOTSTRAP_PASSWORD=change-me
# The admin UI's dev origin — the CSRF origin check 403s browser logins
# without it (the UI on :5175 calls the API on :8794 cross-origin).
ADMIN_ALLOWED_ORIGIN=http://localhost:5175
# Operator session JWT secret; unset = ephemeral per boot (sessions die on
# restart — honest and safe for dev).
# ADMIN_JWT_SECRET=

# ── Partner portal (services/portal :8795) ──────────────────────────────────
# PORTAL_JWT_SECRET=
# PORTAL_API_URL=
# PORTAL_ALLOWED_ORIGIN=
# PORTAL_COOKIE_SECURE=

# ── Service URL overrides (defaults are the local ports) ────────────────────
# GATEWAY_URL=http://localhost:8788
# MEMORY_URL=http://localhost:8792
# MARKET_DATA_URL=http://localhost:8790
# INTELLIGENCE_URL=http://localhost:8791
# ADMIN_API_URL=http://localhost:8794
# HIPPO_SDK_URL=

# ── Misc ────────────────────────────────────────────────────────────────────
# FIXTURES=1            # market-data serves fixtures instead of live CCXT
# VENUE=sim             # seam venue adapter
# HIPPO_DEV=1
# HIPPO_OTEL=1          # OpenTelemetry export (services/intelligence)
# KOINBX_DEV_JWT_SECRET=
