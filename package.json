{
  "name": "hippo-app",
  "private": true,
  "version": "0.1.0",
  "description": "Hippo — conversational trading agent: thin-client SDK, card protocol, gateway services, agentic installer CLI",
  "packageManager": "pnpm@10.18.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "set -a && [ -f .env ] && . ./.env; set +a; turbo run dev --concurrency=20",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^26.1.1",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0"
  }
}
