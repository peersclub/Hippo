{
  "$schema": "https://turborepo.com/schema.json",
  "globalPassThroughEnv": [
    "DATABASE_URL",
    "REDIS_URL",
    "INTERNAL_API_TOKEN",
    "ADMIN_JWT_SECRET",
    "ADMIN_BOOTSTRAP_EMAIL",
    "ADMIN_BOOTSTRAP_PASSWORD",
    "ADMIN_ALLOWED_ORIGIN",
    "GATEWAY_URL",
    "MEMORY_URL",
    "MARKET_DATA_URL",
    "INTELLIGENCE_URL",
    "ADMIN_API_URL",
    "HIPPO_DEV",
    "HIPPO_OTEL",
    "FIXTURES",
    "VENUE",
    "KOINBX_DEV_JWT_SECRET",
    "LLM_BASE_URL",
    "LLM_MODEL",
    "LLM_API_KEY",
    "LLM_TIMEOUT",
    "LLM_INTENT_TIMEOUT",
    "LOG_LEVEL",
    "PORTAL_JWT_SECRET",
    "PORTAL_API_URL",
    "PORTAL_ALLOWED_ORIGIN",
    "PORTAL_COOKIE_SECURE",
    "HIPPO_SDK_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
